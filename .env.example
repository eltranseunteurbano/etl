# ── Alegra API ────────────────────────────────────────────────
ALEGRA_EMAIL=tu_email@ejemplo.com
ALEGRA_TOKEN=tu_token_de_alegra
ALEGRA_BASE_URL=https://api.alegra.com/api/v1

# ── Google Calendar OAuth ─────────────────────────────────────
# Archivos en credentials/ (no versionar; ver credentials/README.md)
GOOGLE_CLIENT_SECRETS_FILE=credentials/client_secrets.json
GOOGLE_TOKEN_FILE=credentials/token.json
# ID del calendario (generalmente tu email de Google)
GOOGLE_CALENDAR_ID=tu_email@gmail.com

# ── Fuentes de datos manuales (Excel) ────────────────────────
# Por defecto apuntan a data/sources/ dentro del proyecto.
# Solo configurar si los Excel están en otra ubicación.
# VENTAS_DIR=data/sources/ventas
# PELUQUERIA_DIR=data/sources/peluqueria

# ── Base de datos ─────────────────────────────────────────────
DB_PATH=data/processed/store.db

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050
DASHBOARD_DEBUG=false
